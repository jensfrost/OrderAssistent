    "expo": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "i18n": "^0.15.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
