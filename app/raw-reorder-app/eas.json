{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_ENV": "dev",
                "EXPO_PUBLIC_API_BASE": "http://10.10.0.13:3003",
                "EXPO_PUBLIC_API_PREFIX": "api",
                "EXPO_PUBLIC_VISMA_API_BASE": "http://10.10.0.13:8001",
                "EXPO_PUBLIC_WOO_BASE_URL": "https://www.aveo.se",
                "EXPO_PUBLIC_WOO_THUMBS_SIZE": "woocommerce_thumbnail",
                "EXPO_PUBLIC_WOO_INCLUDE_PLACEHOLDER": "1",
                "EXPO_PUBLIC_ANDROID_MANIFEST_URL": "http://10.10.0.13/downloads/orderassistent/android.json"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "env": {
                "EXPO_PUBLIC_ENV": "preview",
                "EXPO_PUBLIC_API_BASE": "http://10.10.0.13:3002",
                "EXPO_PUBLIC_API_PREFIX": "api",
                "EXPO_PUBLIC_VISMA_API_BASE": "http://10.10.0.13:8000",
                "EXPO_PUBLIC_WOO_BASE_URL": "https://www.aveo.se",
                "EXPO_PUBLIC_WOO_THUMBS_SIZE": "woocommerce_thumbnail",
                "EXPO_PUBLIC_WOO_INCLUDE_PLACEHOLDER": "1",
                "EXPO_PUBLIC_ANDROID_MANIFEST_URL": "http://10.10.0.13/downloads/orderassistent/android.json"
            }
        },
        "production": {
            "distribution": "store",
            "android": {
                "autoIncrement": true
            },
            "env": {
                "EXPO_PUBLIC_ENV": "prod",
                "EXPO_PUBLIC_API_BASE": "http://10.10.0.13:3002",
                "EXPO_PUBLIC_API_PREFIX": "api",
                "EXPO_PUBLIC_VISMA_API_BASE": "http://10.10.0.13:8000"
            }
        }
    }
}